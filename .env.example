# =============================================================================
# Aquarius Chatbot — env vars
# =============================================================================
# Copy to .env.local for local dev. Production values live in Vercel env vars
# (set per environment: Production / Preview / Development).
# =============================================================================

# -----------------------------------------------------------------------------
# LLM (OpenRouter → Gemini 2.5 Flash)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Stripe — DEPRECATED, replaced by BPoint for Trust Accounting settlement.
# Retained during BPoint rollout soak period (1 week of clean prod usage),
# then the Stripe wiring is removed per design spec.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# BPoint (Commonwealth Bank) — replaces Stripe
# -----------------------------------------------------------------------------
# SCI-only API user created in BPoint Back Office. Dev uses BPoint's sandbox
# endpoint (www.bpoint.com.au/webapi/sandbox) with these same creds. Flip
# BPOINT_ENV=prod to go live — note Aquarius's facility is prod-only, no
# separate UAT environment, so pre-launch smoke test uses a $0.01 txn + refund.
BPOINT_API_USERNAME=
BPOINT_API_PASSWORD=
BPOINT_MERCHANT_NUMBER=
BPOINT_BILLER_CODE=
BPOINT_ENV=sandbox

# -----------------------------------------------------------------------------
# Upstash Redis (session store; 1hr TTL on chat sessions,
# 90d TTL on session→Smokeball-matter mapping)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Zapier — three production Zaps + one dev-only Zap (safety pattern)
# -----------------------------------------------------------------------------
# DEV SAFETY: Every prod Zap has a Filter step "Only continue if isTest is
# false OR does not exist" to block accidental test payloads. Dev/local
# traffic should point ZAPIER_WEBHOOK_URL to Zap #4 (email-only, no Smokeball)
# so nothing can pollute production Smokeball even if the filter fails.
#
# Zap #1 (PROD) — intake + payment → Smokeball Create Matter + tail webhook
#   back to /api/webhooks/smokeball-matter-created for session→matter mapping
ZAPIER_WEBHOOK_URL=
# Zap #2 (PROD) — late document upload → Smokeball Upload File to Matter
ZAPIER_ATTACH_WEBHOOK_URL=
# Zap #3 (PROD) — durable audit log (Google Sheet append or email)
ZAPIER_AUDIT_WEBHOOK_URL=
# Zap #4 (DEV-ONLY) — emails prabu@motionify.co with the payload, never
# touches Smokeball. Dev machines should set ZAPIER_WEBHOOK_URL to this URL.
# In Vercel, leave this blank and ZAPIER_WEBHOOK_URL set to the real Zap #1.
ZAPIER_DEV_WEBHOOK_URL=

# Shared secret for Zap #1's tail "Webhooks by Zapier → POST" step that
# POSTs {sessionId, smokeballMatterId} to our app. Must match the
# X-Smokeball-Capture-Secret header value configured in Zapier.
# Generate with: openssl rand -base64 32
SMOKEBALL_CAPTURE_SECRET=

# -----------------------------------------------------------------------------
# ClickSend (urgent SMS notifications)
# -----------------------------------------------------------------------------
# Alpha sender IDs need ~1-2 business day ClickSend approval. Leave
# CLICKSEND_SENDER_ID blank = SMS goes from ClickSend's shared number.
# Swap to "AquariusLaw" (or whatever alpha tag was approved) once live.
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=
CLICKSEND_SENDER_ID=
# Solicitor's mobile for urgent-matter escalations (E.164 format, +614...)
URGENT_SMS_RECIPIENT=

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
# Sender must be a verified domain in Resend (SPF + DKIM published).
RESEND_API_KEY=
# e.g. "Aquarius Lawyers <marketing@aquariuslawyers.com.au>"
RESEND_FROM_EMAIL=
# Per-upload + per-intake firm notification inbox
FIRM_NOTIFY_EMAIL=

# -----------------------------------------------------------------------------
# Calendly (booking + webhook-driven post-booking workflow)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_CALENDLY_BOOKING_URL=https://calendly.com/ekalaivan/advising-meeting
CALENDLY_BOOKING_URL=https://calendly.com/ekalaivan/advising-meeting
# Personal Access Token with scopes: users:read, webhooks:read, webhooks:write,
# scheduled_events:read. Webhook subscription is created programmatically
# (POST /webhook_subscriptions) rather than via the Calendly UI.
CALENDLY_PERSONAL_ACCESS_TOKEN=
# HMAC-SHA256 signing key we supply at subscription creation (Calendly does
# not echo it back; generate + supply + store here).
CALENDLY_WEBHOOK_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Branding (all optional — defaults to generic "Demo Law Firm")
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIRM_NAME=
NEXT_PUBLIC_FIRM_TAGLINE=Criminal Law Assistant
NEXT_PUBLIC_PRIVACY_URL=/privacy
FIRM_EMAIL_SENDER_NAME=

# -----------------------------------------------------------------------------
# Vercel Blob (late-upload file storage)
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# App URLs + shared secrets
# -----------------------------------------------------------------------------
NEXT_PUBLIC_URL=http://localhost:3000
# Server-only base URL used by late-upload magic link (NOT NEXT_PUBLIC_URL;
# this value never ships to the client).
APP_URL=http://localhost:3000
# Late-upload cookie signing secret (32 random bytes).
# Generate with: openssl rand -base64 32
UPLOAD_COOKIE_SECRET=
# Vercel Cron shared secret (sent as `Authorization: Bearer <CRON_SECRET>`)
CRON_SECRET=

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
# Legacy key — consolidated into FIRM_NOTIFY_EMAIL above. Kept for back-compat
# during the migration; remove once no code references it.
FIRM_NOTIFICATION_EMAIL=
