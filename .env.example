# LLM (OpenRouter)
OPENROUTER_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (MUST be set; webhook verification fails otherwise)
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Zapier
# Phase 1: create-matter Zap (existing)
ZAPIER_WEBHOOK_URL=
# Phase 2 (late upload): attach-file-to-matter Zap
ZAPIER_ATTACH_WEBHOOK_URL=
# Phase 2 (late upload): durable-audit-sheet Zap (Google Sheet append-row)
ZAPIER_AUDIT_WEBHOOK_URL=

# Resend
RESEND_API_KEY=
# e.g. "Aquarius Lawyers <noreply@aquariuslawyers.com.au>"
RESEND_FROM_EMAIL=
# Per-upload firm notification inbox
FIRM_NOTIFY_EMAIL=

# Calendly
NEXT_PUBLIC_CALENDLY_URL=

# Vercel Blob (file uploads)
BLOB_READ_WRITE_TOKEN=

# App
NEXT_PUBLIC_URL=http://localhost:3000
# Server-only base URL used by the late-upload magic link (NOT NEXT_PUBLIC_URL;
# this value never ships to the client).
APP_URL=http://localhost:3000

# Late-upload cookie signing secret (32 random bytes).
# Generate with: openssl rand -base64 32
UPLOAD_COOKIE_SECRET=

# Vercel Cron shared secret (sent as `Authorization: Bearer <CRON_SECRET>`)
CRON_SECRET=

# Calendly booking integration
NEXT_PUBLIC_CALENDLY_BOOKING_URL=https://calendly.com/ekalaivan/advising-meeting
CALENDLY_BOOKING_URL=https://calendly.com/ekalaivan/advising-meeting
CALENDLY_WEBHOOK_SIGNING_KEY=
FIRM_NOTIFICATION_EMAIL=prabu@paretoid.com
